rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Accounts: 
    // - Anyone can read (needed for public key lookup)
    // - Only owner can update (uid stored in doc from Fix 2)
    // - Anyone can create (must be auth-ed, but we don't have uid yet in the write)
    match /accounts/{qc} {
      allow read: if true;
      allow create: if isAuthenticated();
      // Allow update if you are the owner (UID match) 
      // OR if it's a legacy account (no UID) and you are claiming it (adding your UID)
      allow update: if isOwner(resource.data.uid) || (
        !resource.data.uid && request.resource.data.uid == request.auth.uid
      );
      
      // Contacts: any authenticated session can manage this account's contacts.
      // The subcollection path /accounts/{qc}/contacts/ already scopes writes
      // to one account. UID-matching was abandoned because anonymous UIDs change
      // across browsers/sessions causing permanent lockouts.
      match /contacts/{contactSide} {
        allow read, write: if isAuthenticated();
      }
    }

    // Chat Requests: 
    // Relaxed to isAuthenticated() to handle UID-drifting in anonymous sessions.
    // The security is enforced by:
    // 1. Guessing random requestId is hard.
    // 2. Acceptance only affects your own contact list.
    match /chat_requests/{requestId} {
      allow read, update, delete: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.from != request.resource.data.to;
    }

    // Messages: (RESTORED — Accidentally deleted in previous step)
    // - Scoped to /messages/{chatId}/msgs/{msgId}
    // - Must be authenticated to read/write
    match /messages/{chatId}/msgs/{msgId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() 
                    && request.resource.data.from != request.resource.data.to;
      allow update: if isAuthenticated() 
                    && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenByRecipient', 'deliveredByRecipient']));
      allow delete: if isAuthenticated();
    }

    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      
      match /msgs/{msgId} {
        allow read, write: if isAuthenticated();
      }
    }

    match /statuses/{id} {
      allow read, write: if isAuthenticated();
    }

    match /active_numbers/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /burned_numbers/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /erasure_log/{id} {
      allow read, write: if false; // Server-side only
    }
  }
}
