rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Accounts: 
    // - Anyone can read (needed for public key lookup)
    // - Only owner can update (uid stored in doc from Fix 2)
    // - Anyone can create (must be auth-ed, but we don't have uid yet in the write)
    match /accounts/{qc} {
      allow read: if true;
      allow create: if isAuthenticated();
      // Allow update if you are the owner (UID match) 
      // OR if it's a legacy account (no UID) and you are claiming it (adding your UID)
      allow update: if isOwner(resource.data.uid) || (
        !resource.data.uid && request.resource.data.uid == request.auth.uid
      );
      
      // Contacts: Only the owner (the account holder) can read/write their contacts
      match /contacts/{contactSide} {
        allow read, write: if isOwner(get(/databases/$(database)/documents/accounts/$(qc)).data.uid);
      }
    }

    // Chat Requests: 
    // - Must be authenticated to see requests or send them
    // - Support for both new (UID-based) and legacy (QC-based) requests
    match /chat_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.from != request.resource.data.to;
      
      // Allow update if:
      // A) Proper UID match (New format)
      // B) Authentication present (Legacy format fallback for transition)
      allow update: if isAuthenticated() && (
        request.auth.uid == (resource.data.fromUid || "legacy") || 
        request.auth.uid == (resource.data.toUid || "legacy") ||
        (!resource.data.fromUid && !resource.data.toUid) // Allow legacy updates
      );
      
      // Allow delete if you are the sender (to clean up after handshake)
      allow delete: if isAuthenticated() && (
        request.auth.uid == (resource.data.fromUid || "legacy") ||
        (!resource.data.fromUid && !resource.data.toUid) // Allow legacy delete
      );
    }

    // Messages: (RESTORED — Accidentally deleted in previous step)
    // - Scoped to /messages/{chatId}/msgs/{msgId}
    // - Must be authenticated to read/write
    match /messages/{chatId}/msgs/{msgId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() 
                    && request.resource.data.from != request.resource.data.to;
      allow update: if isAuthenticated() 
                    && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenByRecipient', 'deliveredByRecipient']));
      allow delete: if isAuthenticated();
    }

    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      
      match /msgs/{msgId} {
        allow read, write: if isAuthenticated();
      }
    }

    match /statuses/{id} {
      allow read, write: if isAuthenticated();
    }

    match /active_numbers/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /burned_numbers/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /erasure_log/{id} {
      allow read, write: if false; // Server-side only
    }
  }
}
